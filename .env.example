# App
APP_ENV=development
LOG_LEVEL=info

# API
APP_HOST=0.0.0.0
APP_PORT=8080
API_HOST=0.0.0.0
API_PORT=8080
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# Database
DATABASE_DSN=host=localhost user=examora password=examora dbname=examora_dev port=5432 sslmode=disable TimeZone=Asia/Shanghai
DATABASE_URL=postgres://examora:examora@localhost:5432/examora_dev

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379
REDIS_JUDGE_STREAM=examora:judge:tasks

# Judge
JUDGE_MODE=mock
JUDGE_WORKER_CONCURRENCY=4
SANDBOX_ADDR=http://localhost:8081

# Desktop
DESKTOP_API_BASE_URL=http://localhost:8080

# Logto Auth
# Replace <YOUR_APP_ID> with your actual Logto application ID
LOGTO_ENDPOINT=https://auth.micromoving.net/
LOGTO_APP_ID=<YOUR_APP_ID>
LOGTO_ADMIN_REDIRECT_URI=http://localhost:5173/callback
LOGTO_ADMIN_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
LOGTO_DESKTOP_REDIRECT_URI=http://localhost:5174/callback
LOGTO_DESKTOP_POST_LOGOUT_REDIRECT_URI=http://localhost:5174
LOGTO_API_AUDIENCE=examora-api

# Seed Admin (optional)
# If set, the first SUPER_ADMIN user will be auto-created on startup
SEED_ADMIN_SUBJECT=
SEED_ADMIN_DISPLAY_NAME=Admin
