{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@examora/shared-types": ["packages/shared-types/src/index.ts"],
      "@examora/api-client": ["packages/api-client/src/index.ts"]
    }
  }
}
